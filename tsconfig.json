{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    // Environment
    "target": "esnext",
    "module": "commonjs",
    "lib": ["esnext"],
    "types": ["node"],

    // Paths
    "rootDir": "./src",
    "baseUrl": ".",

    // Strictness
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    // DX
    "skipLibCheck": true,
    "moduleResolution": "node"
  },
  "include": ["src"]
}
